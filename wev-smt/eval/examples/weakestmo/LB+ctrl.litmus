C LB+ctrl
(* Weakestmo (Chakraborty & Vafeiadis, POPL 2019), LB+ctrl: a genuine CONTROL      *)
(* dependency on both threads — each store is guarded by a branch on the value      *)
(* just loaded, so the store's occurrence is control-dependent on the load. A       *)
(* store cannot be speculated before its guarding branch, so the dependency is      *)
(* preserved and the r0=r1=1 cycle is thin-air. Weakestmo FORBIDS LB+ctrl.          *)
(*                                                                                  *)
(* The wev-smt C parser flattens the conditional store (no brace/else handling) to  *)
(* a branch-on-read followed by the store and records read->store ctrl with         *)
(* isSemantic=true. Under the CURRENT detector this ctrl edge is in sdep.            *)
{ }
P0(int *x, int *y) { r0 = READ_ONCE(*x); if (r0 == 1) ; WRITE_ONCE(*y, 1); }
P1(int *x, int *y) { r1 = READ_ONCE(*y); if (r1 == 1) ; WRITE_ONCE(*x, 1); }
exists (0:r0=1 /\ 1:r1=1)
